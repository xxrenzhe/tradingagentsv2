//@version=5
indicator("Lightglow V2 + P/D Long - Dual Independent Systems",
     shorttitle="LG+PD Dual",
     overlay=true,
     max_labels_count=500,
     max_lines_count=200)

// ============================================================================
// Purpose
// ============================================================================
//
// This script displays two independent trading systems on one TradingView chart:
//
// 1. Premium/Discount Long 1m
//    - Long only in the discount zone.
//    - Virtual exit after 1 bar by default.
//
// 2. Lightglow Premium/Discount V2 Non-Kill Zone
//    - Long in discount, short in premium.
//    - ATR and non-kill-zone filters.
//    - Virtual exit after 2 bars by default.
//
// TradingView allows only one broker emulator per strategy script. To keep the
// two systems independent, this is an indicator with separate virtual state,
// virtual exits, labels, alerts, and point-based stats for each system.
// ============================================================================

// Premium/Discount Long 1m inputs
enable_pd = input.bool(true, "Enable P/D Long 1m", group="P/D Long 1m")
pd_lookback = input.int(100, "Lookback", minval=10, maxval=500, group="P/D Long 1m")
pd_discount_threshold = input.float(0.05, "Discount Threshold", minval=0.0, maxval=0.5, step=0.01, group="P/D Long 1m")
pd_exit_bars = input.int(1, "Exit After Bars", minval=1, maxval=10, group="P/D Long 1m")

// Lightglow V2 inputs
enable_lg = input.bool(true, "Enable Lightglow V2", group="Lightglow V2")
lg_lookback = input.int(100, "Lookback", minval=10, maxval=500, group="Lightglow V2")
lg_premium_threshold = input.float(0.95, "Premium Threshold", minval=0.5, maxval=1.0, step=0.01, group="Lightglow V2")
lg_discount_threshold = input.float(0.05, "Discount Threshold", minval=0.0, maxval=0.5, step=0.01, group="Lightglow V2")
lg_exit_bars = input.int(2, "Exit After Bars", minval=1, maxval=10, group="Lightglow V2")
lg_atr_length = input.int(14, "ATR Length", minval=5, maxval=50, group="Lightglow V2")
lg_atr_threshold = input.float(8.0, "ATR Threshold", minval=0.0, maxval=50.0, step=0.5, group="Lightglow V2")
use_non_kz_filter = input.bool(true, "Avoid Kill Zone", group="Lightglow V2")
allow_v1_mode = input.bool(false, "V1 Mode: Trade Kill Zone", group="Lightglow V2")

// Display inputs
show_zones = input.bool(true, "Show Zones", group="Display")
show_signals = input.bool(true, "Show Entry/Exit Markers", group="Display")
show_sessions = input.bool(true, "Show Session Backgrounds", group="Display")
show_stats = input.bool(true, "Show Independent Stats", group="Display")
show_pd_position_line = input.bool(false, "Show P/D Virtual Position Line", group="Display")
show_lg_position_line = input.bool(false, "Show Lightglow Virtual Position Line", group="Display")

// Cost model for virtual point stats only
point_value = input.float(20.0, "Point Value", minval=0.01, group="Virtual Stats Cost Model")
commission_round_trip = input.float(10.0, "Round-Trip Commission", minval=0.0, step=0.5, group="Virtual Stats Cost Model")
slippage_ticks_per_side = input.float(2.0, "Slippage Ticks Per Side", minval=0.0, step=0.5, group="Virtual Stats Cost Model")
tick_size = input.float(0.25, "Tick Size", minval=0.01, step=0.01, group="Virtual Stats Cost Model")
round_trip_cost_points = slippage_ticks_per_side * tick_size * 2.0 + commission_round_trip / point_value

// ============================================================================
// Premium/Discount calculations
// ============================================================================

pd_high = ta.highest(high, pd_lookback)
pd_low = ta.lowest(low, pd_lookback)
pd_range = pd_high - pd_low
pd_discount_level = pd_low + pd_discount_threshold * pd_range
pd_in_discount = close <= pd_discount_level

lg_high = ta.highest(high, lg_lookback)
lg_low = ta.lowest(low, lg_lookback)
lg_range = lg_high - lg_low
lg_premium_level = lg_low + lg_premium_threshold * lg_range
lg_discount_level = lg_low + lg_discount_threshold * lg_range
lg_in_premium = close > lg_premium_level
lg_in_discount = close < lg_discount_level

lg_atr = ta.atr(lg_atr_length)
lg_atr_filter = lg_atr > lg_atr_threshold

// ============================================================================
// Lightglow time filter
// ============================================================================

hour_utc = hour(time, "UTC")
minute_utc = minute(time, "UTC")
ny_am = (hour_utc == 13 and minute_utc >= 30) or (hour_utc >= 14 and hour_utc < 16) or (hour_utc == 16 and minute_utc <= 30)
ny_pm = (hour_utc == 18 and minute_utc >= 30) or (hour_utc >= 19 and hour_utc < 21)
is_kill_zone = ny_am or ny_pm
lg_time_filter = allow_v1_mode ? is_kill_zone : (use_non_kz_filter ? not is_kill_zone : true)

is_asian = hour_utc >= 23 or hour_utc < 7
is_london = hour_utc >= 7 and (hour_utc < 13 or (hour_utc == 13 and minute_utc < 30))
is_lunch = (hour_utc == 16 and minute_utc >= 30) or hour_utc == 17 or (hour_utc == 18 and minute_utc < 30)
is_after_hours = hour_utc >= 21 and hour_utc < 23

// ============================================================================
// Independent virtual systems
// ============================================================================

var bool pd_in_trade = false
var int pd_entry_bar = na
var float pd_entry_price = na
var int pd_trades = 0
var int pd_wins = 0
var float pd_net_points = 0.0
var float pd_gross_profit = 0.0
var float pd_gross_loss = 0.0
var float pd_peak_points = 0.0
var float pd_max_dd_points = 0.0

var bool lg_in_trade = false
var int lg_entry_bar = na
var float lg_entry_price = na
var int lg_direction = 0
var int lg_trades = 0
var int lg_wins = 0
var int lg_longs = 0
var int lg_shorts = 0
var float lg_net_points = 0.0
var float lg_gross_profit = 0.0
var float lg_gross_loss = 0.0
var float lg_peak_points = 0.0
var float lg_max_dd_points = 0.0

pd_entry_signal = enable_pd and not pd_in_trade and pd_in_discount
lg_long_signal = enable_lg and not lg_in_trade and lg_in_discount and lg_atr_filter and lg_time_filter
lg_short_signal = enable_lg and not lg_in_trade and lg_in_premium and lg_atr_filter and lg_time_filter

pd_exit_signal = pd_in_trade and bar_index - pd_entry_bar >= pd_exit_bars
lg_exit_signal = lg_in_trade and bar_index - lg_entry_bar >= lg_exit_bars

var float pd_last_net = na
var float lg_last_net = na

if pd_exit_signal
    pd_gross_points = close - pd_entry_price
    pd_last_net := pd_gross_points - round_trip_cost_points
    pd_trades += 1
    if pd_last_net > 0
        pd_wins += 1
        pd_gross_profit += pd_last_net
    else
        pd_gross_loss += math.abs(pd_last_net)
    pd_net_points += pd_last_net
    pd_peak_points := math.max(pd_peak_points, pd_net_points)
    pd_max_dd_points := math.max(pd_max_dd_points, pd_peak_points - pd_net_points)
    pd_in_trade := false
    pd_entry_bar := na
    pd_entry_price := na

if lg_exit_signal
    lg_gross_points = (close - lg_entry_price) * lg_direction
    lg_last_net := lg_gross_points - round_trip_cost_points
    lg_trades += 1
    if lg_last_net > 0
        lg_wins += 1
        lg_gross_profit += lg_last_net
    else
        lg_gross_loss += math.abs(lg_last_net)
    lg_net_points += lg_last_net
    lg_peak_points := math.max(lg_peak_points, lg_net_points)
    lg_max_dd_points := math.max(lg_max_dd_points, lg_peak_points - lg_net_points)
    lg_in_trade := false
    lg_entry_bar := na
    lg_entry_price := na
    lg_direction := 0

if pd_entry_signal
    pd_in_trade := true
    pd_entry_bar := bar_index
    pd_entry_price := close

if lg_long_signal
    lg_in_trade := true
    lg_entry_bar := bar_index
    lg_entry_price := close
    lg_direction := 1
    lg_longs += 1
else if lg_short_signal
    lg_in_trade := true
    lg_entry_bar := bar_index
    lg_entry_price := close
    lg_direction := -1
    lg_shorts += 1

// ============================================================================
// Visualization
// ============================================================================

plot(show_zones ? pd_discount_level : na, "P/D Long Discount Level", color=color.new(color.green, 20), linewidth=2)
plot(show_zones ? lg_premium_level : na, "Lightglow Premium Level", color=color.new(color.red, 60), linewidth=1)
plot(show_zones ? lg_discount_level : na, "Lightglow Discount Level", color=color.new(color.teal, 60), linewidth=1)

pd_discount_fill = plot(show_zones ? pd_low : na, display=display.none)
pd_discount_line = plot(show_zones ? pd_discount_level : na, display=display.none)
fill(pd_discount_fill, pd_discount_line, color=color.new(color.green, 92), title="P/D Long Discount Zone")

lg_premium_fill = plot(show_zones ? lg_high : na, display=display.none)
lg_premium_line = plot(show_zones ? lg_premium_level : na, display=display.none)
fill(lg_premium_fill, lg_premium_line, color=color.new(color.red, 95), title="Lightglow Premium Zone")

lg_discount_fill = plot(show_zones ? lg_low : na, display=display.none)
lg_discount_line = plot(show_zones ? lg_discount_level : na, display=display.none)
fill(lg_discount_fill, lg_discount_line, color=color.new(color.teal, 95), title="Lightglow Discount Zone")

plotshape(show_signals and pd_entry_signal, "P/D Long Entry", shape.triangleup, location.belowbar, color.new(color.green, 0), size=size.tiny, text="PD L")
plotshape(show_signals and pd_exit_signal, "P/D Long Exit", shape.xcross, location.abovebar, color.new(color.green, 0), size=size.tiny, text="PD X")

plotshape(show_signals and lg_long_signal, "Lightglow Long Entry", shape.triangleup, location.belowbar, color.new(color.teal, 0), size=size.tiny, text="LG L")
plotshape(show_signals and lg_short_signal, "Lightglow Short Entry", shape.triangledown, location.abovebar, color.new(color.red, 0), size=size.tiny, text="LG S")
plotshape(show_signals and lg_exit_signal ? close : na, "Lightglow Exit", shape.xcross, location.absolute, color.new(color.orange, 0), size=size.tiny, text="LG X")

plot(show_pd_position_line and pd_in_trade ? pd_entry_price : na, "P/D Virtual Entry", color=color.new(color.green, 0), linewidth=1, style=plot.style_circles)
plot(show_lg_position_line and lg_in_trade ? lg_entry_price : na, "Lightglow Virtual Entry", color=color.new(color.orange, 0), linewidth=1, style=plot.style_circles)

bgcolor(show_sessions and is_kill_zone ? color.new(color.red, 95) : na, title="Kill Zone")
bgcolor(show_sessions and is_asian ? color.new(color.blue, 97) : na, title="Asian Session")
bgcolor(show_sessions and is_london ? color.new(color.orange, 97) : na, title="London Session")
bgcolor(show_sessions and is_lunch ? color.new(color.gray, 97) : na, title="Lunch Session")
bgcolor(show_sessions and is_after_hours ? color.new(color.purple, 97) : na, title="After Hours")

// ============================================================================
// Independent statistics table
// ============================================================================

pd_pf = pd_gross_loss > 0 ? pd_gross_profit / pd_gross_loss : (pd_gross_profit > 0 ? 999.0 : 0.0)
lg_pf = lg_gross_loss > 0 ? lg_gross_profit / lg_gross_loss : (lg_gross_profit > 0 ? 999.0 : 0.0)
pd_wr = pd_trades > 0 ? pd_wins / pd_trades * 100.0 : 0.0
lg_wr = lg_trades > 0 ? lg_wins / lg_trades * 100.0 : 0.0
pd_status = pd_in_trade ? "LONG" : "FLAT"
lg_status = lg_in_trade ? (lg_direction > 0 ? "LONG" : "SHORT") : "FLAT"

if show_stats and barstate.islast
    var table stats = table.new(position.top_right, 3, 13, border_width=1)
    table.cell(stats, 0, 0, "Metric", text_color=color.white, bgcolor=color.new(color.blue, 20), text_size=size.small)
    table.cell(stats, 1, 0, "P/D Long", text_color=color.white, bgcolor=color.new(color.green, 20), text_size=size.small)
    table.cell(stats, 2, 0, "Lightglow V2", text_color=color.white, bgcolor=color.new(color.red, 20), text_size=size.small)

    table.cell(stats, 0, 1, "Status", text_size=size.small)
    table.cell(stats, 1, 1, pd_status, text_size=size.small)
    table.cell(stats, 2, 1, lg_status, text_size=size.small)

    table.cell(stats, 0, 2, "Trades", text_size=size.small)
    table.cell(stats, 1, 2, str.tostring(pd_trades), text_size=size.small)
    table.cell(stats, 2, 2, str.tostring(lg_trades), text_size=size.small)

    table.cell(stats, 0, 3, "Win Rate", text_size=size.small)
    table.cell(stats, 1, 3, str.tostring(pd_wr, "#.#") + "%", text_size=size.small)
    table.cell(stats, 2, 3, str.tostring(lg_wr, "#.#") + "%", text_size=size.small)

    table.cell(stats, 0, 4, "Profit Factor", text_size=size.small)
    table.cell(stats, 1, 4, str.tostring(pd_pf, "#.##"), text_size=size.small)
    table.cell(stats, 2, 4, str.tostring(lg_pf, "#.##"), text_size=size.small)

    table.cell(stats, 0, 5, "Net Points", text_size=size.small)
    table.cell(stats, 1, 5, str.tostring(pd_net_points, "#,###.##"), text_color=pd_net_points >= 0 ? color.green : color.red, text_size=size.small)
    table.cell(stats, 2, 5, str.tostring(lg_net_points, "#,###.##"), text_color=lg_net_points >= 0 ? color.green : color.red, text_size=size.small)

    table.cell(stats, 0, 6, "Net Dollars", text_size=size.small)
    table.cell(stats, 1, 6, str.tostring(pd_net_points * point_value, "$#,###.##"), text_color=pd_net_points >= 0 ? color.green : color.red, text_size=size.small)
    table.cell(stats, 2, 6, str.tostring(lg_net_points * point_value, "$#,###.##"), text_color=lg_net_points >= 0 ? color.green : color.red, text_size=size.small)

    table.cell(stats, 0, 7, "Max DD Pts", text_size=size.small)
    table.cell(stats, 1, 7, str.tostring(pd_max_dd_points, "#,###.##"), text_size=size.small)
    table.cell(stats, 2, 7, str.tostring(lg_max_dd_points, "#,###.##"), text_size=size.small)

    table.cell(stats, 0, 8, "Last Net", text_size=size.small)
    table.cell(stats, 1, 8, na(pd_last_net) ? "-" : str.tostring(pd_last_net, "#.##"), text_size=size.small)
    table.cell(stats, 2, 8, na(lg_last_net) ? "-" : str.tostring(lg_last_net, "#.##"), text_size=size.small)

    table.cell(stats, 0, 9, "LG Long/Short", text_size=size.small)
    table.cell(stats, 1, 9, "-", text_size=size.small)
    table.cell(stats, 2, 9, str.tostring(lg_longs) + " / " + str.tostring(lg_shorts), text_size=size.small)

    table.cell(stats, 0, 10, "Cost / Trade", text_size=size.small)
    table.cell(stats, 1, 10, str.tostring(round_trip_cost_points, "#.##") + " pts", text_size=size.small)
    table.cell(stats, 2, 10, str.tostring(round_trip_cost_points, "#.##") + " pts", text_size=size.small)

    table.cell(stats, 0, 11, "LG ATR", text_size=size.small)
    table.cell(stats, 1, 11, "-", text_size=size.small)
    table.cell(stats, 2, 11, str.tostring(lg_atr, "#.##"), text_size=size.small)

    table.cell(stats, 0, 12, "Kill Zone", text_size=size.small)
    table.cell(stats, 1, 12, "-", text_size=size.small)
    table.cell(stats, 2, 12, is_kill_zone ? "YES" : "NO", text_size=size.small)

// ============================================================================
// Alerts
// ============================================================================

alertcondition(pd_entry_signal, "P/D Long Entry", "P/D Long independent system: long entry")
alertcondition(pd_exit_signal, "P/D Long Exit", "P/D Long independent system: time exit")
alertcondition(lg_long_signal, "Lightglow V2 Long Entry", "Lightglow V2 independent system: long entry")
alertcondition(lg_short_signal, "Lightglow V2 Short Entry", "Lightglow V2 independent system: short entry")
alertcondition(lg_exit_signal, "Lightglow V2 Exit", "Lightglow V2 independent system: time exit")
