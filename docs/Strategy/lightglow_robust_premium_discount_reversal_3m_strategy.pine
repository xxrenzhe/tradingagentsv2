//@version=5
strategy(
     "Lightglow Best Premium/Discount Reversal 1m",
     shorttitle="LG Best P/D 1m",
     overlay=true,
     pyramiding=0,
     initial_capital=100000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     commission_type=strategy.commission.cash_per_contract,
     commission_value=0,
     slippage=0,
     scale=scale.left,
     max_labels_count=500,
     max_lines_count=500,
     max_boxes_count=100)

strategyGroup = "Strategy"
swingLength = input.int(50, "Swing Length", minval=10, group=strategyGroup)
showZones = input.bool(true, "Show Premium/Discount Zones", group=strategyGroup)
showLabels = input.bool(true, "Show Trade Labels", group=strategyGroup)
showTradeLines = input.bool(true, "Show Entry/Exit Lines", group=strategyGroup)
showDashboard = input.bool(true, "Show Dashboard", group=strategyGroup)
pointValue = input.float(2.0, "Point Value", minval=0.0, step=0.25, group=strategyGroup)
roundTripCostPoints = input.float(0.0, "Round Trip Cost Points", minval=0.0, step=0.25, group=strategyGroup)

colorGroup = "Colors"
premiumColor = input.color(color.rgb(242, 54, 69), "Premium Zone", group=colorGroup)
discountColor = input.color(color.rgb(8, 153, 129), "Discount Zone", group=colorGroup)
equilibriumColor = input.color(color.rgb(135, 139, 148), "Equilibrium", group=colorGroup)
longColor = input.color(color.rgb(0, 160, 90), "Long", group=colorGroup)
shortColor = input.color(color.rgb(220, 60, 65), "Short", group=colorGroup)
winColor = input.color(color.rgb(0, 150, 136), "Win Label", group=colorGroup)
lossColor = input.color(color.rgb(244, 67, 54), "Loss Label", group=colorGroup)

if not timeframe.isminutes or timeframe.multiplier != 1
    runtime.error("Apply this script on a 1-minute chart. The selected best strategy is defined on 1m bars.")

BULLISH = 1
BEARISH = -1
HOLD_BARS = 2

var float swingTop = na
var float swingBottom = na
var int swingTopIndex = na
var int swingBottomIndex = na
var int orderedDirection = 0
var int orderedSignalIndex = na
var int manualPosition = 0
var int manualEntryIndex = na
var float manualEntryPrice = na
var float manualEquityPoints = 0.0
var float manualPeakPoints = 0.0
var float manualMaxDrawdownPoints = 0.0
var int manualTrades = 0
var int manualWins = 0
var float manualGrossWins = 0.0
var float manualGrossLosses = 0.0
var label dashboard = na
var box premiumBox = na
var box discountBox = na
var box equilibriumBox = na

pivotHigh = ta.pivothigh(high, swingLength, swingLength)
pivotLow = ta.pivotlow(low, swingLength, swingLength)

if not na(pivotHigh)
    swingTop := pivotHigh
    swingTopIndex := bar_index - swingLength

if not na(pivotLow)
    swingBottom := pivotLow
    swingBottomIndex := bar_index - swingLength

hasRange = not na(swingTop) and not na(swingBottom) and swingTop > swingBottom
premiumFloor = hasRange ? 0.95 * swingTop + 0.05 * swingBottom : na
discountCeiling = hasRange ? 0.05 * swingTop + 0.95 * swingBottom : na
equilibriumTop = hasRange ? 0.525 * swingTop + 0.475 * swingBottom : na
equilibriumBottom = hasRange ? 0.525 * swingBottom + 0.475 * swingTop : na

rawZoneSignal = hasRange and close >= premiumFloor ? BEARISH : hasRange and close <= discountCeiling ? BULLISH : 0
reverseSignal = -rawZoneSignal
tradeSignal = reverseSignal != 0

if showZones and hasRange and barstate.islast
    leftIndex = math.min(nz(swingTopIndex, bar_index), nz(swingBottomIndex, bar_index))
    rightIndex = bar_index
    if na(premiumBox)
        premiumBox := box.new(leftIndex, swingTop, rightIndex, premiumFloor, bgcolor=color.new(premiumColor, 86), border_color=color.new(premiumColor, 70))
        discountBox := box.new(leftIndex, discountCeiling, rightIndex, swingBottom, bgcolor=color.new(discountColor, 86), border_color=color.new(discountColor, 70))
        equilibriumBox := box.new(leftIndex, equilibriumTop, rightIndex, equilibriumBottom, bgcolor=color.new(equilibriumColor, 88), border_color=color.new(equilibriumColor, 75))
    else
        box.set_lefttop(premiumBox, leftIndex, swingTop)
        box.set_rightbottom(premiumBox, rightIndex, premiumFloor)
        box.set_lefttop(discountBox, leftIndex, discountCeiling)
        box.set_rightbottom(discountBox, rightIndex, swingBottom)
        box.set_lefttop(equilibriumBox, leftIndex, equilibriumTop)
        box.set_rightbottom(equilibriumBox, rightIndex, equilibriumBottom)

enteredLong = false
enteredShort = false
scheduledLong = false
scheduledShort = false
if barstate.isnew and manualPosition == 0 and orderedDirection != 0 and bar_index == orderedSignalIndex + 1
    manualPosition := orderedDirection
    manualEntryIndex := bar_index
    manualEntryPrice := open
    enteredLong := manualPosition > 0
    enteredShort := manualPosition < 0
    if showLabels
        entryText = manualPosition > 0 ? "LONG\nEntry " + str.tostring(manualEntryPrice, format.mintick) : "SHORT\nEntry " + str.tostring(manualEntryPrice, format.mintick)
        label.new(bar_index, manualPosition > 0 ? low : high, entryText, style=manualPosition > 0 ? label.style_label_up : label.style_label_down, color=manualPosition > 0 ? color.new(longColor, 0) : color.new(shortColor, 0), textcolor=color.white, size=size.small)
    orderedDirection := 0
    orderedSignalIndex := na

exitNow = barstate.isconfirmed and manualPosition != 0 and bar_index == manualEntryIndex + HOLD_BARS - 1
if exitNow
    exitPrice = close
    grossPoints = (exitPrice - manualEntryPrice) * manualPosition
    netPoints = grossPoints - roundTripCostPoints
    manualTrades += 1
    manualWins += netPoints > 0 ? 1 : 0
    manualGrossWins += netPoints > 0 ? netPoints : 0.0
    manualGrossLosses += netPoints < 0 ? math.abs(netPoints) : 0.0
    manualEquityPoints += netPoints
    manualPeakPoints := math.max(manualPeakPoints, manualEquityPoints)
    manualMaxDrawdownPoints := math.max(manualMaxDrawdownPoints, manualPeakPoints - manualEquityPoints)
    strategy.close(manualPosition > 0 ? "LG Long" : "LG Short", comment="Time exit 2x1m", immediately=true)
    if showTradeLines
        line.new(manualEntryIndex, manualEntryPrice, bar_index, exitPrice, color=netPoints >= 0 ? color.new(winColor, 0) : color.new(lossColor, 0), width=2)
    if showLabels
        directionText = manualPosition > 0 ? "LONG" : "SHORT"
        resultText = netPoints >= 0 ? "WIN +" : "LOSS "
        labelText = directionText + " EXIT\n" + resultText + str.tostring(netPoints, "#.##") + " pts\nEquity " + str.tostring(manualEquityPoints, "#.##") + " pts"
        label.new(bar_index, manualPosition > 0 ? high : low, labelText, style=manualPosition > 0 ? label.style_label_down : label.style_label_up, color=netPoints >= 0 ? color.new(winColor, 0) : color.new(lossColor, 0), textcolor=color.white, size=size.small)
    manualPosition := 0
    manualEntryIndex := na
    manualEntryPrice := na

if barstate.isconfirmed and manualPosition == 0 and orderedDirection == 0 and tradeSignal
    orderedDirection := reverseSignal
    orderedSignalIndex := bar_index
    scheduledLong := reverseSignal > 0
    scheduledShort := reverseSignal < 0
    if reverseSignal > 0
        strategy.entry("LG Long", strategy.long, comment="Long reverse discount")
    else
        strategy.entry("LG Short", strategy.short, comment="Short reverse premium")

plot(hasRange ? premiumFloor : na, "Premium Floor", color=color.new(premiumColor, 20), linewidth=1)
plot(hasRange ? discountCeiling : na, "Discount Ceiling", color=color.new(discountColor, 20), linewidth=1)
plot(hasRange ? math.avg(swingTop, swingBottom) : na, "Equilibrium", color=color.new(equilibriumColor, 45), linewidth=1)
plot(manualEquityPoints, "Manual Equity Points", color=color.rgb(33, 87, 243), linewidth=2)
plot(manualMaxDrawdownPoints, "Max Drawdown Points", color=color.new(lossColor, 0), linewidth=1)
hline(0, "Equity Zero", color=color.new(color.gray, 70), linestyle=hline.style_dotted)

plotshape(scheduledLong, "Reverse Long Signal", shape.triangleup, location.belowbar, color=color.new(longColor, 0), size=size.tiny, text="Rev L")
plotshape(scheduledShort, "Reverse Short Signal", shape.triangledown, location.abovebar, color=color.new(shortColor, 0), size=size.tiny, text="Rev S")
plotshape(enteredLong, "Long Entry", shape.circle, location.belowbar, color=color.new(longColor, 0), size=size.tiny)
plotshape(enteredShort, "Short Entry", shape.circle, location.abovebar, color=color.new(shortColor, 0), size=size.tiny)
plotshape(exitNow, "Time Exit", shape.xcross, location.absolute, color=color.new(color.white, 0), size=size.tiny)

if showDashboard and barstate.islast
    winRate = manualTrades > 0 ? 100.0 * manualWins / manualTrades : 0.0
    profitFactor = manualGrossLosses > 0 ? manualGrossWins / manualGrossLosses : manualGrossWins > 0 ? 999.0 : 0.0
    equityDollars = manualEquityPoints * pointValue
    dashText = "Lightglow Best P/D 1m\n" +
         "Rules: reverse zone signal, next 1m open, hold 2 bars\n" +
         "Candidate: lightglow_premium_discount_reversal_1m_all_hold2m_reverse_time\n" +
         "Trades: " + str.tostring(manualTrades) + "\n" +
         "Win Rate: " + str.tostring(winRate, "#.##") + "%\n" +
         "Net: " + str.tostring(manualEquityPoints, "#.##") + " pts / $" + str.tostring(equityDollars, "#.##") + "\n" +
         "PF: " + str.tostring(profitFactor, "#.###") + "\n" +
         "Max DD: " + str.tostring(manualMaxDrawdownPoints, "#.##") + " pts"
    if na(dashboard)
        dashboard := label.new(bar_index, high, dashText, style=label.style_label_left, color=color.new(color.black, 12), textcolor=color.white, size=size.normal)
    else
        label.set_xy(dashboard, bar_index, high)
        label.set_text(dashboard, dashText)

alertcondition(scheduledLong, "Lightglow Best Long Signal", "Best Lightglow reverse discount long signal. Entry next 1m open, exit after 2 bars.")
alertcondition(scheduledShort, "Lightglow Best Short Signal", "Best Lightglow reverse premium short signal. Entry next 1m open, exit after 2 bars.")
